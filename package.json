{
  "name": "tabby-ssh-keymap",
  "version": "1.0.1",
  "description": "A Tabby plugin that replaces absolute SSH key paths with logical names in your synced config, while keeping the real file paths local to each machine.",
  "keywords": [
    "tabby-plugin",
    "ssh",
    "keymap",
    "config-sync"
  ],
  "main": "dist/index.js",
  "typings": "typings/index.d.ts",
  "author": "Mathys Lopinto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mathys-lopinto/tabby-ssh-keymap.git"
  },
  "bugs": {
    "url": "https://github.com/mathys-lopinto/tabby-ssh-keymap/issues"
  },
  "homepage": "https://github.com/mathys-lopinto/tabby-ssh-keymap#readme",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "webpack --progress --color --mode production",
    "watch": "webpack --progress --color --watch",
    "prepare": "yarn build"
  },
  "peerDependencies": {
    "@angular/common": "^15",
    "@angular/core": "^15",
    "@angular/forms": "^15",
    "@angular/platform-browser": "^15",
    "@ng-bootstrap/ng-bootstrap": "^14",
    "rxjs": "^7",
    "tabby-core": "*",
    "tabby-settings": "*"
  },
